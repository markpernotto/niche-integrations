# Niche Partner API - Per-Integration Credentials
# Niche requires a unique client_id and client_secret for EACH integration.
# Register each integration at https://app.nicheandleads.com to get credentials.

# -----------------------------------------------------------------------------
# WordPress Integration
# -----------------------------------------------------------------------------
NICHE_WORDPRESS_CLIENT_ID=your_wordpress_client_id
NICHE_WORDPRESS_CLIENT_SECRET=your_wordpress_client_secret

# -----------------------------------------------------------------------------
# Facebook Lead Ads Integration
# -----------------------------------------------------------------------------
NICHE_FACEBOOK_LEADS_CLIENT_ID=your_facebook_leads_client_id
NICHE_FACEBOOK_LEADS_CLIENT_SECRET=your_facebook_leads_client_secret

# -----------------------------------------------------------------------------
# HubSpot Integration
# -----------------------------------------------------------------------------
NICHE_HUBSPOT_CLIENT_ID=your_hubspot_client_id
NICHE_HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
HUBSPOT_CLIENT_SECRET=your_hubspot_app_client_secret
# HUBSPOT_PORT=7777

# -----------------------------------------------------------------------------
# Shared
# -----------------------------------------------------------------------------
NICHE_BUSINESS_ID=your_business_id_from_niche_dashboard
NICHE_API_BASE_URL=https://app.nicheandleads.com

# Rate limiting (optional). Default: 2.
# NICHE_RATE_LIMIT_PER_SECOND=2

# Server ports (optional). Defaults: WordPress 3333, Facebook Leads 6666.
# PORT=3333

# -----------------------------------------------------------------------------
# Facebook Lead Ads (Meta for Developers)
# -----------------------------------------------------------------------------
# FACEBOOK_ACCESS_TOKEN=...
# FACEBOOK_APP_SECRET=...
# FACEBOOK_VERIFY_TOKEN=niche_verify_token
