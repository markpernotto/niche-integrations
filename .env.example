# =============================================================================
# Niche Partner API — Shared
# =============================================================================
NICHE_BUSINESS_ID=your_business_id_from_niche_dashboard
NICHE_API_BASE_URL=https://app.nicheandleads.com

# =============================================================================
# WordPress Integration (PHP plugin — no server)
# =============================================================================
NICHE_WORDPRESS_CLIENT_ID=your_wordpress_client_id
NICHE_WORDPRESS_CLIENT_SECRET=your_wordpress_client_secret
# Credentials are set in WP Admin → Settings → Niche Lead Capture, NOT here.

# =============================================================================
# Facebook Lead Ads (port 6666)
# =============================================================================
NICHE_FACEBOOK_LEADS_CLIENT_ID=your_facebook_leads_client_id
NICHE_FACEBOOK_LEADS_CLIENT_SECRET=your_facebook_leads_client_secret
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=your_long_lived_page_access_token  # expires — regenerate via Graph API Explorer
FACEBOOK_VERIFY_TOKEN=niche_verify_token                 # any string, must match FB App Dashboard

# =============================================================================
# Jobber (port 9003)
# =============================================================================
NICHE_JOBBER_CLIENT_ID=your_niche_jobber_client_id
NICHE_JOBBER_CLIENT_SECRET=your_niche_jobber_client_secret
JOBBER_CLIENT_ID=your_jobber_app_client_id
JOBBER_CLIENT_SECRET=your_jobber_app_client_secret
# JOBBER_REDIRECT_URI=http://localhost:9003/callback     # set to Railway URL in production

# =============================================================================
# Salesforce (port 9004)
# =============================================================================
NICHE_SALESFORCE_CLIENT_ID=your_niche_salesforce_client_id
NICHE_SALESFORCE_CLIENT_SECRET=your_niche_salesforce_client_secret
SALESFORCE_CLIENT_ID=your_salesforce_consumer_key
SALESFORCE_CLIENT_SECRET=your_salesforce_consumer_secret
# SALESFORCE_REDIRECT_URI=http://localhost:9004/callback # set to Railway URL in production

# =============================================================================
# Zoho CRM (port 9005)
# =============================================================================
NICHE_ZOHO_CRM_CLIENT_ID=your_niche_zoho_crm_client_id
NICHE_ZOHO_CRM_CLIENT_SECRET=your_niche_zoho_crm_client_secret
ZOHO_CLIENT_ID=your_zoho_consumer_key
ZOHO_CLIENT_SECRET=your_zoho_consumer_secret
# ZOHO_REDIRECT_URI=http://localhost:9005/callback       # set to Railway URL in production

# =============================================================================
# Freshsales (port 9006)
# =============================================================================
NICHE_FRESHSALES_CLIENT_ID=your_niche_freshsales_client_id
NICHE_FRESHSALES_CLIENT_SECRET=your_niche_freshsales_client_secret
FRESHSALES_API_KEY=your_freshsales_api_key               # Profile Settings → Your API Key (inside CRM product)
FRESHSALES_DOMAIN=yourcompany                            # just the subdomain, e.g. "yourcompany" from yourcompany.myfreshworks.com

# =============================================================================
# Close CRM (port 9008)
# =============================================================================
NICHE_CLOSE_CRM_CLIENT_ID=your_niche_close_crm_client_id
NICHE_CLOSE_CRM_CLIENT_SECRET=your_niche_close_crm_client_secret
CLOSE_CRM_API_KEY=your_close_api_key                     # Close Settings → API Keys

# =============================================================================
# ActiveCampaign (port 9010)
# =============================================================================
NICHE_ACTIVECAMPAIGN_CLIENT_ID=your_niche_activecampaign_client_id
NICHE_ACTIVECAMPAIGN_CLIENT_SECRET=your_niche_activecampaign_client_secret
ACTIVECAMPAIGN_API_KEY=your_activecampaign_api_key       # Settings → Developer → API Key
ACTIVECAMPAIGN_BASE_URL=https://youraccountname.api-us1.com  # Settings → Developer → API URL

# =============================================================================
# Pipedrive (port 9011)
# =============================================================================
NICHE_PIPEDRIVE_CLIENT_ID=your_niche_pipedrive_client_id
NICHE_PIPEDRIVE_CLIENT_SECRET=your_niche_pipedrive_client_secret
PIPEDRIVE_API_TOKEN=your_pipedrive_personal_api_token    # Settings → Personal preferences → API

# =============================================================================
# HubSpot (port 7777)
# =============================================================================
NICHE_HUBSPOT_CLIENT_ID=your_niche_hubspot_client_id
NICHE_HUBSPOT_CLIENT_SECRET=your_niche_hubspot_client_secret
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token      # HubSpot → Settings → Integrations → Private Apps

# =============================================================================
# Microsoft Dynamics 365 (port 9007)
# =============================================================================
NICHE_DYNAMICS365_CLIENT_ID=your_niche_dynamics365_client_id
NICHE_DYNAMICS365_CLIENT_SECRET=your_niche_dynamics365_client_secret
DYNAMICS_TENANT_ID=your_azure_directory_tenant_id        # Azure Portal → Entra ID → Overview
DYNAMICS_CLIENT_ID=your_azure_app_client_id              # Azure Portal → App registrations → your app
DYNAMICS_CLIENT_SECRET=your_azure_app_client_secret      # Azure Portal → App registrations → Certificates & secrets
DYNAMICS_INSTANCE_URL=https://yourorg.crm.dynamics.com   # Power Apps admin center → Environments → your env
